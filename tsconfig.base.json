{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022"],
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "baseUrl": ".",
    "paths": {
      "@rewards-audit/db": ["packages/db/src/index.ts"],
      "@rewards-audit/shared-types": ["packages/shared-types/src/index.ts"],
      "@rewards-audit/rewards-engine": ["packages/rewards-engine/src/index.ts"]
    }
  }
}
